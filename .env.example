# Social Hub (local)
DATABASE_URL="file:./prisma/social.db"
SOCIAL_HUB_PASSWORD="change-me"
SOCIAL_MEDIA_BASE_URL="https://www.shelfieease.app"
REPO_ROOT="."

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://www.shelfieease.app
TIKTOK_REFRESH_TOKEN=
TIKTOK_USE_DIRECT_POST=true
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_GRAPH_VERSION=v21.0

# Blotato (planning + publish) — https://my.blotato.com → Settings → API
BLOTATO_API_KEY=
# Optioneel: kies specifiek account als je meerdere hebt gekoppeld
BLOTATO_TIKTOK_USERNAME=shelfieease
BLOTATO_INSTAGRAM_USERNAME=shelfieease
