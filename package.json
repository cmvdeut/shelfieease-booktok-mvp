{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack && next-sitemap",
    "tiktok-data": "node scripts/generate-tiktok-data.js",
    "build:cf": "cross-env CF_PAGES=1 next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "cross-env DATABASE_URL=file:./prisma/social.db prisma migrate dev",
    "db:push": "cross-env DATABASE_URL=file:./prisma/social.db prisma db push",
    "social:seed": "cross-env DATABASE_URL=file:./prisma/social.db tsx scripts/social-seed.ts",
    "social:publish": "cross-env DATABASE_URL=file:./prisma/social.db tsx scripts/social-publish.ts",
    "social:worker": "cross-env DATABASE_URL=file:./prisma/social.db tsx scripts/social-worker.ts",
    "social:worker:once": "cross-env DATABASE_URL=file:./prisma/social.db tsx scripts/social-worker.ts --once",
    "social:setup": "npm run db:push && npm run social:seed",
    "social:sync-pilars": "node scripts/sync-pilars-to-public.js",
    "social:export-sheet": "node scripts/export-social-sheet.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@upstash/redis": "^1.36.1",
    "@zxing/browser": "^0.1.5",
    "html-to-image": "^1.11.13",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^3.0.4",
    "date-fns": "^4.1.0",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "19.2.1",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react-big-calendar": "^1.16.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "next-sitemap": "^4.2.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
